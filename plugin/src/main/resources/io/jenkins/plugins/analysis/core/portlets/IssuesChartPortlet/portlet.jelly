<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:dp="/hudson/plugins/view/dashboard" xmlns:st="jelly:stapler" xmlns:c="/charts">

  <j:set var="model" value="${it.register(jobs)}"/>

  <dp:decorate portlet="${it}" width="1">
    <tr>
      <td>
        <c:trend-chart it="${it}" enableLinks="false" configurationId="default"/>
      </td>
    </tr>
  </dp:decorate>

</j:jelly>
